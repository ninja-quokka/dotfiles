#!/usr/bin/env bash
# prepare-commit-msg hook: uses Claude to draft a commit message from staged changes
# The message appears in your editor for review/editing before committing.

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Only generate for normal commits (not merges, squashes, amends, etc.)
if [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

# Check if claude CLI is available
if ! command -v claude &>/dev/null; then
  exit 0
fi

# Get the staged diff
DIFF=$(git diff --cached)

# Skip if nothing is staged
if [ -z "$DIFF" ]; then
  exit 0
fi

# Generate commit message using Claude
MSG=$(claude --print --model claude-sonnet-4-5-20250514 \
  "Write a concise git commit message for the following staged diff. Follow conventional commit style if appropriate. Output ONLY the commit message, nothing else. Keep the first line under 72 characters. Add a blank line then a brief body if the change warrants explanation." \
  <<< "$DIFF" 2>/dev/null)

# Only replace if claude succeeded and returned something
if [ $? -eq 0 ] && [ -n "$MSG" ]; then
  # Preserve any existing comments (like the verbose diff git adds)
  COMMENTS=$(grep '^#' "$COMMIT_MSG_FILE")
  printf '%s\n\n%s\n' "$MSG" "$COMMENTS" > "$COMMIT_MSG_FILE"
fi
