theme = teide-darker

font-family = Maple Mono NF
font-family-italic = Maple Mono NF
font-family-bold-italic = Maple Mono NF
font-size = 18
font-thicken = true

cursor-style-blink = false
scrollback-limit = 2147483648
macos-option-as-alt = true

clipboard-read = allow
clipboard-write = allow

quick-terminal-position = center

macos-titlebar-style = hidden
macos-window-shadow = false
window-decoration = false
window-padding-x = 0
window-padding-y = 0
window-padding-color = extend
window-padding-balance = false
window-step-resize = true

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# Make mouse scroll higher resolution
mouse-scroll-multiplier = 1

# Keybindings
# Note: grave means backtick like `
# Note: glabal is needed her to launch quick terminal
#       when Ghostty isn't in focus
keybind = global:ctrl+grave_accent=toggle_quick_terminal
